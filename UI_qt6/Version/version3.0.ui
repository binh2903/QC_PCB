  <property name="styleSheet">
   <string notr="true">/* GLOBAL DARK THEME */
* {
    font-family: &quot;Segoe UI&quot;, Roboto, Arial, sans-serif;
}
QMainWindow {
    background-color: #121212;
}
QWidget#centralwidget {
    background-color: #121212;
}
QLabel {
    color: #E0E0E0;
}
/* PANELS &amp; TITLE BAR */
QFrame#title_bar {
    background-color: #1A1A2E;
    border-bottom: 2px solid #282846;
}
QFrame#frame_settings_panel {
    background-color: #1A1A2E;
    border-radius: 8px;
    border: 1px solid #333333;
}
QGroupBox {
    background-color: #1E1E1E;
    border: 1px solid #333333;
    border-radius: 6px;
    margin-top: 12px;
    padding-top: 15px;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 10px;
    color: #00E676;
    font-weight: bold;
    font-size: 13px;
}
/* NAVIGATION BUTTONS */
QPushButton#btn_nav_inspection {
    background-color: #00E676;
    color: #121212;
    border-radius: 6px;
    font-weight: bold;
    padding: 8px 16px;
}
QPushButton#btn_nav_settings {
    background-color: #333333;
    color: #AAAAAA;
    border: 1px solid #555555;
    border-radius: 6px;
    font-weight: bold;
    padding: 8px 16px;
}
QPushButton#btn_nav_settings:hover { background-color: #444444; color: white; }

/* GENERAL BUTTONS */
QPushButton {
    background-color: #2D2D2D;
    color: white;
    border: 1px solid #444444;
    border-radius: 4px;
    padding: 6px;
}
QPushButton:hover { background-color: #3D3D3D; border-color: #00E676; }
QPushButton:pressed { background-color: #1E1E1E; }

/* ACTION BUTTONS (INSPECTION PAGE) */
QPushButton#btn_start { background-color: #00C853; border: none; font-size: 16px; font-weight: bold; color: white; border-radius: 8px;}
QPushButton#btn_start:hover { background-color: #00E676; }
QPushButton#btn_reset { background-color: #FDD835; border: none; font-size: 16px; font-weight: bold; color: #121212; border-radius: 8px;}
QPushButton#btn_reset:hover { background-color: #FFEE58; }
QPushButton#btn_stop { background-color: #E53935; border: none; font-size: 16px; font-weight: bold; color: white; border-radius: 8px;}
QPushButton#btn_stop:hover { background-color: #EF5350; }

QPushButton#btn_add_log { background-color: #00C853; border:none; font-weight:bold; }
QPushButton#btn_delete_log { background-color: #E53935; border:none; font-weight:bold; }

/* INPUTS &amp; CONTROLS (SETTINGS PAGE) */
QComboBox {
    background-color: #222222;
    color: white;
    border: 1px solid #444444;
    border-radius: 4px;
    padding: 5px;
    font-size: 13px;
}
QComboBox::drop-down { border: none; }
QLineEdit {
    background-color: #121212;
    color: #00E676;
    border: 1px solid #444444;
    border-radius: 4px;
    padding: 4px;
}
QRadioButton, QCheckBox {
    color: #E0E0E0;
    spacing: 8px;
}
QRadioButton::indicator, QCheckBox::indicator {
    width: 16px; height: 16px;
}

/* LCD NUMBERS */
QLCDNumber {
    background-color: #0A0A0A;
    color: #00E676;
    border: 1px solid #333333;
    border-radius: 4px;
}
/* TABLE WIDGET */
QTableWidget {
    background-color: #181818;
    alternate-background-color: #222222;
    color: #E0E0E0;
    gridline-color: #333333;
    border: 1px solid #333333;
    border-radius: 4px;
}
QHeaderView::section {
    background-color: #1A1A2E;
    color: white;
    font-weight: bold;
    padding: 4px;
    border: 1px solid #333333;
}</string>
